{
    "display_information": {
        "name": "Pulse",
        "description": "Truelist's data analyst and business intelligence engine.",
        "background_color": "#000000"
    },
    "features": {
        "bot_user": {
            "display_name": "Pulse",
            "always_online": true
        },
        "slash_commands": [
            {
                "command": "/openclaw",
                "description": "Send a message to OpenClaw",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "user": [
                "groups:history",
                "im:history",
                "channels:read",
                "groups:read",
                "mpim:read",
                "channels:history",
                "mpim:history",
                "pins:read",
                "reactions:read"
            ],
            "bot": [
                "app_mentions:read",
                "channels:history",
                "channels:read",
                "chat:write",
                "commands",
                "groups:history",
                "groups:read",
                "im:history",
                "im:read",
                "im:write",
                "mpim:history",
                "mpim:read",
                "pins:read",
                "pins:write",
                "reactions:read",
                "reactions:write",
                "users:read",
                "files:read"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "user_events": [
                "channel_rename",
                "member_joined_channel",
                "member_left_channel",
                "message.app_home",
                "message.channels",
                "message.groups",
                "message.mpim",
                "pin_added",
                "pin_removed",
                "reaction_added",
                "reaction_removed"
            ],
            "bot_events": [
                "app_mention",
                "channel_rename",
                "member_joined_channel",
                "member_left_channel",
                "message.channels",
                "message.groups",
                "message.im",
                "message.mpim",
                "pin_added",
                "pin_removed",
                "reaction_added",
                "reaction_removed"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}
